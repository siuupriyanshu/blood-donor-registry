<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.blooddonor.controller.DonationRecorderController"
      spacing="15" style="-fx-padding: 20;">

    <Label text="Record New Donation" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <Separator/>

    <!-- Form Fields -->
    <GridPane hgap="15" vgap="15">
        <!-- Row 1: Donor Selection -->
        <Label text="Donor:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="donorCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300"/>

        <!-- Row 2: Donation Date -->
        <Label text="Donation Date:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="donationDatePicker" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="300"/>

        <!-- Row 3: Volume Collected -->
        <Label text="Volume Collected (ml):" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Spinner fx:id="volumeSpinner" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="300"/>

        <!-- Row 4: Status -->
        <Label text="Status:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="statusCombo" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="300"/>

        <!-- Row 5: Notes -->
        <Label text="Notes:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-valignment: top;"/>
        <TextArea fx:id="notesArea" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="300" prefHeight="100" wrapText="true"/>

        <!-- Column Constraints -->
        <columnConstraints>
            <ColumnConstraints prefWidth="150"/>
            <ColumnConstraints prefWidth="300"/>
        </columnConstraints>
    </GridPane>

    <Separator/>

    <!-- Info Label -->
    <Label fx:id="infoLabel" text="" style="-fx-text-fill: #666666; -fx-font-size: 11;"/>

    <!-- Buttons -->
    <HBox spacing="10" style="-fx-alignment: center-right;">
        <Button text="Record Donation" onAction="#handleRecordDonation" style="-fx-padding: 10 30; -fx-font-size: 12;"/>
        <Button text="Cancel" onAction="#handleCancel" style="-fx-padding: 10 30; -fx-font-size: 12;"/>
    </HBox>

</VBox>
